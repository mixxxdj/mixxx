<?xml version="1.0" encoding="utf-8"?>
<!-- USB device filter for DJ controllers -->
<!-- DDJ-FLX4: VID=0x2B73 (AlphaTheta Corporation/Pioneer DJ), PID=0x0045 -->
<!-- DDJ-400: VID=0x2B73, PID=0x0043 -->
<!-- Generic MIDI controllers: class=1 (Audio), subclass=3 (MIDI) -->
<resources>
    <!-- Pioneer/AlphaTheta DJ controllers (vendor 0x2B73 = 11123) -->
    <usb-device vendor-id="11123" product-id="69" />
    <!-- DDJ-FLX4 PID 0x0045 = 69 -->
    <usb-device vendor-id="11123" product-id="67" />
    <!-- DDJ-400 PID 0x0043 = 67 -->
    <!-- Generic class-based MIDI devices (fallback) -->
    <usb-device class="1" subclass="3" />
</resources>
