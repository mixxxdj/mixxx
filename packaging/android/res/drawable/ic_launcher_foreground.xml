<?xml version="1.0" encoding="utf-8"?>
<!--
  DJ Sugar adaptive icon foreground.
  Simplified vinyl record matching the DJ Sugar SVG icon:
  dark vinyl disc with groove rings, pink centre label, tonearm.
  Fits the standard 108x108 dp adaptive-icon canvas; all meaningful
  graphics inside the 72x72 dp safe zone.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── Vinyl record disc (outer) ── -->
    <path
        android:pathData="M54,54 m-38,0 a38,38 0 1,0 76,0 a38,38 0 1,0 -76,0"
        android:fillColor="#FF3D2050"/>

    <!-- Groove rings — concentric semi-transparent white lines. -->
    <path
        android:pathData="M54,54 m-34,0 a34,34 0 1,0 68,0"
        android:strokeColor="#33FFFFFF"
        android:strokeWidth="0.35"
        android:fillColor="#00000000"/>
    <path
        android:pathData="M54,54 m-30,0 a30,30 0 1,0 60,0"
        android:strokeColor="#33FFFFFF"
        android:strokeWidth="0.35"
        android:fillColor="#00000000"/>
    <path
        android:pathData="M54,54 m-26,0 a26,26 0 1,0 52,0"
        android:strokeColor="#33FFFFFF"
        android:strokeWidth="0.35"
        android:fillColor="#00000000"/>
    <path
        android:pathData="M54,54 m-22,0 a22,22 0 1,0 44,0"
        android:strokeColor="#33FFFFFF"
        android:strokeWidth="0.35"
        android:fillColor="#00000000"/>
    <path
        android:pathData="M54,54 m-19,0 a19,19 0 1,0 38,0"
        android:strokeColor="#33FFFFFF"
        android:strokeWidth="0.35"
        android:fillColor="#00000000"/>
    <path
        android:pathData="M54,54 m-16,0 a16,16 0 1,0 32,0"
        android:strokeColor="#33FFFFFF"
        android:strokeWidth="0.35"
        android:fillColor="#00000000"/>

    <!-- Outer edge highlight ring. -->
    <path
        android:pathData="M54,54 m-37,0 a37,37 0 1,0 74,0"
        android:strokeColor="#26FFFFFF"
        android:strokeWidth="1"
        android:fillColor="#00000000"/>

    <!-- ── Centre label ── -->
    <path
        android:pathData="M54,54 m-14,0 a14,14 0 1,0 28,0"
        android:fillColor="#FFE4467F"/>
    <!-- Subtle inner border on label. -->
    <path
        android:pathData="M54,54 m-13,0 a13,13 0 1,0 26,0"
        android:strokeColor="#59FFFFFF"
        android:strokeWidth="0.5"
        android:fillColor="#00000000"/>

    <!-- Label abbreviation "DS" (DJ Sugar) in white, bold. -->
    <path
        android:pathData="M49.5,51 L49.5,46 L52.5,46 A3,3 0 0,1 52.5,51 Z M50.5,47 L50.5,50.2 L52,50.2 A1.8,1.8 0 0,0 52,47 Z"
        android:fillColor="#FFFFFFFF"/>

    <path
        android:pathData="M55.5,52.5 A2.5,2.5 0 0,1 55.5,49 L59,49 L55.5,52.5 Z M56,50 L58,50 L56,51.5 Z M55.5,55 A2.5,2.5 0 0,1 55.5,53 L59,53 L59,54 L56.5,54 A1.5,1.5 0 0,0 56.5,55 Z"
        android:fillColor="#FFFFFFFF"/>

    <!-- Spindle hole. -->
    <path
        android:pathData="M54,54 m-1.5,0 a1.5,1.5 0 1,0 3,0"
        android:fillColor="#FF0D0012"/>

    <!-- ── Tonearm (decorative, top-right) ── -->
    <!-- Pivot base. -->
    <path
        android:pathData="M82,26 m-3.5,0 a3.5,3.5 0 1,0 7,0"
        android:fillColor="#FFC0C0CC"/>
    <path
        android:pathData="M82,26 m-1.5,0 a1.5,1.5 0 1,0 3,0"
        android:fillColor="#FF6E6E80"/>

    <!-- Arm tube. -->
    <path
        android:pathData="M81.5,27.5 L66,42"
        android:strokeColor="#FFE8E8F0"
        android:strokeWidth="2"
        android:strokeLineCap="round"/>

    <!-- Headshell. -->
    <path
        android:pathData="M64,40 L68,38.5 L69.5,41 L65.5,42.5 Z"
        android:fillColor="#FFF0F0F8"/>

    <!-- Stylus tip — glowing pink dot. -->
    <path
        android:pathData="M63.5,41.5 m-1.2,0 a1.2,1.2 0 1,0 2.4,0"
        android:fillColor="#FFEA2A4E"/>
</vector>
