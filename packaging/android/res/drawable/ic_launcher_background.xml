<?xml version="1.0" encoding="utf-8"?>
<!--
  DJ Sugar adaptive icon background.
  Uses the same pink-to-deep-purple gradient as the SVG icon.
  Viewport is the standard 108x108 dp adaptive-icon canvas.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- Full-bleed background circle matching the SVG icon's gradient. -->
    <!-- We draw a circle at (54,54) r=54 to cover the full adaptive zone. -->
    <path android:pathData="M54,54 m-54,0 a54,54 0 1,0 108,0 a54,54 0 1,0 -108,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="70"
                android:type="radial">
                <item android:offset="0" android:color="#FFE4467F"/>
                <item android:offset="1" android:color="#FF1A0930"/>
            </gradient>
        </aapt:attr>
    </path>
</vector>
