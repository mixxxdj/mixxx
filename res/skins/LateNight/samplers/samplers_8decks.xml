<Template>

  <SingletonDefinition>
    <ObjectName>Samplers_Expander_<Variable name="Count"/>_Singleton</ObjectName>
    <Children>
      <Template src="skins:LateNight/samplers/sampler_expand_button.xml"/>
    </Children>
  </SingletonDefinition>

  <WidgetGroup>
    <ObjectName>SamplerContainer</ObjectName>
    <Layout>horizontal</Layout>
    <SizePolicy>me,max</SizePolicy>
    <Children>

      <WidgetGroup>
        <Layout>horizontal</Layout>
        <SizePolicy>me,min</SizePolicy>
        <Children>

          <!-- 8 small Samplers -->
          <WidgetGroup>
            <ObjectName>SamplerRow</ObjectName>
            <Layout>horizontal</Layout>
            <SizePolicy>min,min</SizePolicy>
            <Children>

              <SingletonContainer>
                <ObjectName>SamplerMini1_Singleton</ObjectName>
              </SingletonContainer>

              <SingletonContainer>
                <ObjectName>SamplerMini2_Singleton</ObjectName>
              </SingletonContainer>

              <SingletonContainer>
                <ObjectName>SamplerMini3_Singleton</ObjectName>
              </SingletonContainer>

              <SingletonContainer>
                <ObjectName>SamplerMini4_Singleton</ObjectName>
              </SingletonContainer>

              <SingletonContainer>
                <ObjectName>Samplers_Expander_<Variable name="Count"/>_Singleton</ObjectName>
              </SingletonContainer>

              <Template src="skins:LateNight/samplers/sampler_mini.xml">
                <SetVariable name="SamplerNum">5</SetVariable>
              </Template>

              <Template src="skins:LateNight/samplers/sampler_mini.xml">
                <SetVariable name="SamplerNum">6</SetVariable>
              </Template>

              <Template src="skins:LateNight/samplers/sampler_mini.xml">
                <SetVariable name="SamplerNum">7</SetVariable>
              </Template>

              <Template src="skins:LateNight/samplers/sampler_mini.xml">
                <SetVariable name="SamplerNum">8</SetVariable>
              </Template>

            </Children>
            <Connection>
              <ConfigKey persist="true">[LateNight],expand_samplers_<Variable name="Count"/></ConfigKey>
              <BindProperty>visible</BindProperty>
              <Transform><Not/></Transform>
            </Connection>
          </WidgetGroup>

          <!-- 8 big Samplers -->
          <WidgetGroup on_hide_select="0">
            <Layout>vertical</Layout>
            <SizePolicy>min,min</SizePolicy>
            <Children>

              <!-- First row 1 2 | 5 6 (or alternatively 1 2 | 3 4 if using alternate_samplers_order skin setting)-->
              <WidgetGroup>
                <ObjectName>SamplerRow</ObjectName>
                <Layout>horizontal</Layout>
                <SizePolicy>min,min</SizePolicy>
                <Children>

                  <SingletonContainer>
                    <ObjectName>Sampler1_Singleton</ObjectName>
                  </SingletonContainer>

                  <SingletonContainer>
                    <ObjectName>Sampler2_Singleton</ObjectName>
                  </SingletonContainer>

                  <SingletonContainer>
                    <ObjectName>Samplers_Expander_<Variable name="Count"/>_Singleton</ObjectName>
                  </SingletonContainer>

                  <!-- using WidgetStack in order to conditionally switch between the two layouts (3 and 5)-->
                  <WidgetStack currentpage="[LateNight],alternate_samplers_order" persist="true">
                    <Children>
                      <WidgetGroup>
                        <Layout>horizontal</Layout>
                        <SizePolicy>me,min</SizePolicy>
                        <Children>
                    <Template src="skins:LateNight/samplers/sampler.xml">
                      <SetVariable name="SamplerNum">5</SetVariable>
                    </Template>
                        </Children>
                      </WidgetGroup>
                      <!-- Page 1 : use_alternate_order = 1 -->
                      <WidgetGroup>
                        <Layout>horizontal</Layout>
                        <SizePolicy>me,min</SizePolicy>
                        <Children>
                    <Template src="skins:LateNight/samplers/sampler.xml">
                      <SetVariable name="SamplerNum">3</SetVariable>
                    </Template>
                        </Children>
                      </WidgetGroup>
                    </Children>
                  </WidgetStack>

                  <!-- using WidgetStack in order to conditionally switch between the two layouts (4 and 6)-->
                  <WidgetStack currentpage="[LateNight],alternate_samplers_order" persist="true">
                    <Children>
                      <WidgetGroup>
                        <Layout>horizontal</Layout>
                        <SizePolicy>me,min</SizePolicy>
                        <Children>
                    <Template src="skins:LateNight/samplers/sampler.xml">
                      <SetVariable name="SamplerNum">6</SetVariable>
                    </Template>
                        </Children>
                      </WidgetGroup>
                      <!-- Page 1 : use_alternate_order = 1 -->
                      <WidgetGroup>
                        <Layout>horizontal</Layout>
                        <SizePolicy>me,min</SizePolicy>
                        <Children>
                    <Template src="skins:LateNight/samplers/sampler.xml">
                      <SetVariable name="SamplerNum">4</SetVariable>
                    </Template>
                        </Children>
                      </WidgetGroup>
                    </Children>
                  </WidgetStack>

                </Children>
              </WidgetGroup><!-- /First row -->

              <!-- Second row 3 4 | 7 8 (or alternatively 5 6 | 7 8 if using alternate_samplers_order skin setting)-->
              <WidgetGroup>
                <ObjectName>SamplerRow</ObjectName>
                <SizePolicy>min,min</SizePolicy>
                <Layout>horizontal</Layout>
                <Children>

                  <!-- using WidgetStack in order to conditionally switch between the two layouts (3 and 5)-->
                  <WidgetStack currentpage="[LateNight],alternate_samplers_order" persist="true">
                    <Children>
                      <WidgetGroup>
                        <Layout>horizontal</Layout>
                        <SizePolicy>me,min</SizePolicy>
                        <Children>
                  <SingletonContainer>
                    <ObjectName>Sampler3_Singleton</ObjectName>
                  </SingletonContainer>
                        </Children>
                      </WidgetGroup>
                      <!-- Page 1 : use_alternate_order = 1 -->
                      <WidgetGroup>
                        <Layout>horizontal</Layout>
                        <SizePolicy>me,min</SizePolicy>
                        <Children>
                    <Template src="skins:LateNight/samplers/sampler.xml">
                      <SetVariable name="SamplerNum">5</SetVariable>
                    </Template>
                        </Children>
                      </WidgetGroup>
                    </Children>
                  </WidgetStack>

                  <!-- using WidgetStack in order to conditionally switch between the two layouts (4 and 6)-->
                  <WidgetStack currentpage="[LateNight],alternate_samplers_order" persist="true">
                    <Children>
                      <WidgetGroup>
                        <Layout>horizontal</Layout>
                        <SizePolicy>me,min</SizePolicy>
                        <Children>
                  <SingletonContainer>
                    <ObjectName>Sampler4_Singleton</ObjectName>
                  </SingletonContainer>
                        </Children>
                      </WidgetGroup>
                      <!-- Page 1 : use_alternate_order = 1 -->
                      <WidgetGroup>
                        <Layout>horizontal</Layout>
                        <SizePolicy>me,min</SizePolicy>
                        <Children>
                    <Template src="skins:LateNight/samplers/sampler.xml">
                      <SetVariable name="SamplerNum">6</SetVariable>
                    </Template>
                        </Children>
                      </WidgetGroup>
                    </Children>
                  </WidgetStack>

                  <!-- <SingletonContainer>
                    <ObjectName>Sampler3_Singleton</ObjectName>
                  </SingletonContainer>

                  <SingletonContainer>
                    <ObjectName>Sampler4_Singleton</ObjectName>
                  </SingletonContainer> -->

                  <WidgetGroup>
                    <ObjectName>MicAuxRackFiller</ObjectName>
                    <Size>20f,1me</Size>
                  </WidgetGroup>

                  <Template src="skins:LateNight/samplers/sampler.xml">
                    <SetVariable name="SamplerNum">7</SetVariable>
                  </Template>

                  <Template src="skins:LateNight/samplers/sampler.xml">
                    <SetVariable name="SamplerNum">8</SetVariable>
                  </Template>

                </Children>
              </WidgetGroup>
              <!-- /Second row -->

            </Children>
            <Connection>
              <ConfigKey persist="true">[LateNight],expand_samplers_<Variable name="Count"/></ConfigKey>
              <BindProperty>visible</BindProperty>
            </Connection>
          </WidgetGroup>

        </Children>
      </WidgetGroup>

    </Children>
  </WidgetGroup>
</Template>
